<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context="com.Saisi_Note1">
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/nom_application"
        android:textSize="22sp"
        android:textStyle="bold"
        android:padding="16sp"
        android:textColor="@color/blue"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#2E7D32"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CALCUL MOYENNE"
            android:textColor="@color/text_color"
            android:textSize="24dp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:gravity="center"/>
    </LinearLayout>
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="16dp"
        app:cardCornerRadius="12sp"
        app:cardElevation="4dp">
        <LinearLayout
            android:background="@color/text_color"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:id="@+id/tvNotesStudentName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Eleve: Toukam Ange"
                android:textColor="@color/black"
                android:textSize="18dp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Semestre 2"
                android:textSize="16dp"
                android:layout_marginTop="4dp"/>
            <View
                android:id="@+id/bar"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginVertical="12dp"/>
            <TextView
                android:id="@+id/tvMoyenneGenerale"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MOYENNE GENERALE: --/20"
                android:textColor="@color/black"
                android:textSize="16dp"
                android:layout_marginBottom="16dp"
                android:textStyle="bold"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Merise (/20)"
                    android:textSize="16sp"
                    android:textColor="@color/black"/>
                <EditText
                    android:id="@+id/etBaseDonne"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:textColorHint="@color/black"
                    android:textColor="@color/black"
                    android:inputType="numberDecimal"
                    android:hint="16"
                    android:gravity="center"
                    android:background="@android:drawable/editbox_background_normal"/>
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginVertical="12dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="JAVA (/20)"
                    android:textSize="16sp"
                    android:textColor="@color/black"/>
                <EditText
                    android:id="@+id/etAlgo"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:textColorHint="@color/black"
                    android:textColor="@color/black"
                    android:inputType="numberDecimal"
                    android:hint="14"
                    android:gravity="center"
                    android:background="@android:drawable/editbox_background_normal"/>
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginVertical="12dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Programmation Mobile (/20)"
                    android:textSize="16sp"
                    android:textColor="@color/black"/>
                <EditText
                    android:id="@+id/etProbabilite"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:hint="10"
                    android:textColorHint="@color/black"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:background="@android:drawable/editbox_background_normal"/>
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginVertical="12dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cloud Computing (/20)"
                    android:textSize="16sp"
                    android:textColor="@color/black"/>
                <EditText
                    android:id="@+id/etAnglais"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:hint="16"
                    android:textColorHint="@color/black"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:background="@android:drawable/editbox_background_normal"/>
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginVertical="12dp"/>
            <Button
                android:id="@+id/btnCalculer"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="CALCULER ET VALIDER"
                android:backgroundTint="@color/blue"
                android:textStyle="bold"
                android:textColor="@color/text_color"/>
            <Button
                android:id="@+id/btnAnnuler"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="ANNULER"
                android:backgroundTint="@color/text_secondaire"
                android:layout_marginTop="8dp"
                android:textStyle="bold"
                android:textColor="@color/text_color"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>